<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
<style>
  :root {
    --bg: #0d1117; --bg2: #161b22; --bg3: #21262d;
    --text: #e6edf3; --text2: #8b949e;
    --green: #3fb950; --red: #f85149; --yellow: #d29922; --blue: #58a6ff;
    --purple: #a371f7; --border: #30363d;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; }
  .container { max-width: 1100px; margin: 0 auto; padding: 24px; }
  header { background: var(--bg2); border-bottom: 1px solid var(--border); padding: 24px; margin-bottom: 24px; border-radius: 8px; }
  header h1 { font-size: 24px; font-weight: 700; }
  header h1 span { color: var(--purple); }
  .meta { color: var(--text2); font-size: 13px; margin-top: 8px; }
  .summary { display: flex; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
  .stat-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 8px; padding: 20px; flex: 1; min-width: 140px; text-align: center; }
  .stat-card .number { font-size: 36px; font-weight: 800; }
  .stat-card .label { font-size: 12px; color: var(--text2); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 4px; }
  .stat-card.pass .number { color: var(--green); }
  .stat-card.fail .number { color: var(--red); }
  .stat-card.warn .number { color: var(--yellow); }
  .stat-card.total .number { background: linear-gradient(135deg, var(--purple), var(--blue)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  section { background: var(--bg2); border: 1px solid var(--border); border-radius: 8px; padding: 20px; margin-bottom: 16px; }
  section h2 { font-size: 16px; font-weight: 600; margin-bottom: 12px; color: var(--purple); }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th { text-align: left; padding: 8px 12px; color: var(--text2); font-weight: 600; border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; }
  td { padding: 8px 12px; border-bottom: 1px solid rgba(48,54,61,0.5); }
  tr:hover td { background: rgba(56,58,65,0.2); }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 600; }
  .badge.pass { background: rgba(63,185,80,0.15); color: var(--green); }
  .badge.fail { background: rgba(248,81,73,0.15); color: var(--red); }
  .badge.warn { background: rgba(210,153,34,0.15); color: var(--yellow); }
  .module-row td:first-child { font-weight: 600; }
  .duration { color: var(--text2); font-size: 12px; }
  footer { text-align: center; color: var(--text2); font-size: 12px; padding: 24px; }
  footer a { color: var(--purple); text-decoration: none; }

  /* Charts layout */
  .charts-row { display: flex; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
  .charts-row section { flex: 1; min-width: 320px; }

  /* Donut chart */
  .donut-wrapper { display: flex; align-items: center; justify-content: center; gap: 32px; padding: 12px 0; flex-wrap: wrap; }
  .donut-svg { width: 180px; height: 180px; transform: rotate(-90deg); }
  .donut-ring { fill: none; stroke: var(--bg3); stroke-width: 20; }
  .donut-segment-pass { fill: none; stroke: var(--green); stroke-width: 20; stroke-linecap: round; transition: stroke-dasharray 0.6s ease; }
  .donut-segment-fail { fill: none; stroke: var(--red); stroke-width: 20; stroke-linecap: round; transition: stroke-dasharray 0.6s ease; }
  .donut-center { position: absolute; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .donut-center .pct-value { font-size: 28px; font-weight: 800; color: var(--green); }
  .donut-center .pct-label { font-size: 11px; color: var(--text2); text-transform: uppercase; letter-spacing: 0.5px; }
  .donut-container { position: relative; width: 180px; height: 180px; display: flex; align-items: center; justify-content: center; }
  .donut-legend { display: flex; flex-direction: column; gap: 10px; }
  .legend-item { display: flex; align-items: center; gap: 8px; font-size: 13px; }
  .legend-swatch { width: 12px; height: 12px; border-radius: 3px; flex-shrink: 0; }
  .legend-swatch.pass { background: var(--green); }
  .legend-swatch.fail { background: var(--red); }
  .legend-count { color: var(--text2); font-size: 12px; }

  /* Module bar chart */
  .bar-chart { display: flex; flex-direction: column; gap: 10px; padding: 8px 0; }
  .bar-row { display: flex; align-items: center; gap: 12px; }
  .bar-label { flex: 0 0 180px; font-size: 12px; color: var(--text); text-align: right; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .bar-track { flex: 1; height: 22px; background: var(--bg3); border-radius: 4px; overflow: hidden; display: flex; position: relative; }
  .bar-fill-pass { background: var(--green); height: 100%; transition: width 0.4s ease; }
  .bar-fill-fail { background: var(--red); height: 100%; transition: width 0.4s ease; }
  .bar-counts { flex: 0 0 80px; font-size: 11px; color: var(--text2); white-space: nowrap; }
  @media (max-width: 600px) {
    .bar-label { flex: 0 0 100px; font-size: 11px; }
    .donut-wrapper { gap: 16px; }
  }
</style>
</head>
<body>
<div class="container">
  <header>
    <h1>MLTK <span>Test Report</span></h1>
    <div class="meta">{{ timestamp }} | {{ title }}</div>
  </header>

  <div class="summary">
    <div class="stat-card total"><div class="number">{{ total }}</div><div class="label">Total Tests</div></div>
    <div class="stat-card pass"><div class="number">{{ passed }}</div><div class="label">Passed</div></div>
    <div class="stat-card fail"><div class="number">{{ failed }}</div><div class="label">Failed</div></div>
    <div class="stat-card warn"><div class="number">{{ "%.1f"|format(duration) }}s</div><div class="label">Duration</div></div>
  </div>

  {% if total > 0 %}
  <div class="charts-row">
    <section>
      <h2>Pass / Fail</h2>
      <div class="donut-wrapper">
        <div class="donut-container">
          <svg class="donut-svg" viewBox="0 0 180 180">
            <circle class="donut-ring" cx="90" cy="90" r="70"></circle>
            {% if passed > 0 %}
            <circle class="donut-segment-pass" cx="90" cy="90" r="70"
              stroke-dasharray="{{ pass_arc }} {{ circumference }}"
              stroke-dashoffset="0"></circle>
            {% endif %}
            {% if failed > 0 %}
            <circle class="donut-segment-fail" cx="90" cy="90" r="70"
              stroke-dasharray="{{ fail_arc }} {{ circumference }}"
              stroke-dashoffset="-{{ pass_arc }}"></circle>
            {% endif %}
          </svg>
          <div class="donut-center" style="position:absolute;top:0;left:0;width:180px;height:180px;display:flex;flex-direction:column;align-items:center;justify-content:center;pointer-events:none;">
            <span class="pct-value" {% if pass_pct < 50 %}style="color:var(--red)"{% endif %}>{{ pass_pct }}%</span>
            <span class="pct-label">passed</span>
          </div>
        </div>
        <div class="donut-legend">
          <div class="legend-item">
            <span class="legend-swatch pass"></span>
            <span>Passed</span>
            <span class="legend-count">{{ passed }}</span>
          </div>
          <div class="legend-item">
            <span class="legend-swatch fail"></span>
            <span>Failed</span>
            <span class="legend-count">{{ failed }}</span>
          </div>
        </div>
      </div>
    </section>

    {% if modules %}
    <section>
      <h2>Module Breakdown</h2>
      <div class="bar-chart">
        {% for mod in modules %}
        <div class="bar-row">
          <div class="bar-label" title="{{ mod.name }}">{{ mod.name.split('/')[-1] }}</div>
          <div class="bar-track">
            {% if mod.passed > 0 %}
            <div class="bar-fill-pass" style="width:{{ (mod.passed / max_module_total * 100)|round(1) }}%"></div>
            {% endif %}
            {% if mod.failed > 0 %}
            <div class="bar-fill-fail" style="width:{{ (mod.failed / max_module_total * 100)|round(1) }}%"></div>
            {% endif %}
          </div>
          <div class="bar-counts">{{ mod.passed }}&#x2713; {{ mod.failed }}&#x2717;</div>
        </div>
        {% endfor %}
      </div>
    </section>
    {% endif %}
  </div>
  {% endif %}

  {% if modules %}
  <section>
    <h2>Results by Module</h2>
    <table>
      <tr><th>Module</th><th>Passed</th><th>Failed</th><th>Total</th><th>Status</th></tr>
      {% for mod in modules %}
      <tr class="module-row">
        <td>{{ mod.name }}</td>
        <td>{{ mod.passed }}</td>
        <td>{{ mod.failed }}</td>
        <td>{{ mod.total }}</td>
        <td><span class="badge {{ 'pass' if mod.failed == 0 else 'fail' }}">{{ 'PASS' if mod.failed == 0 else 'FAIL' }}</span></td>
      </tr>
      {% endfor %}
    </table>
  </section>
  {% endif %}

  {% if results %}
  <section>
    <h2>Test Details</h2>
    <table>
      <tr><th>Test</th><th>Status</th><th>Duration</th><th>Details</th></tr>
      {% for r in results %}
      <tr>
        <td>{{ r.nodeid }}</td>
        <td><span class="badge {{ r.outcome }}">{{ r.outcome | upper }}</span></td>
        <td class="duration">{{ "%.3f"|format(r.duration) }}s</td>
        <td>{{ r.message or '' }}</td>
      </tr>
      {% endfor %}
    </table>
  </section>
  {% endif %}

  <footer>
    Generated by <a href="https://github.com/Liorrr/mltk">mltk</a> — pytest for ML
  </footer>
</div>
</body>
</html>
